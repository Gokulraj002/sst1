<script>
// Chart instance registry to prevent duplicates
var chartInstances = {};
function safeChart(id, config) {
  var ctx = document.getElementById(id);
  if (!ctx) return null;
  if (chartInstances[id]) chartInstances[id].destroy();
  chartInstances[id] = new Chart(ctx, config);
  return chartInstances[id];
}

// Page Titles for ALL 25 modules
const PAGE_TITLES = {
  'dashboard': 'Dashboard',
  'leads': 'Leads Management',
  'quotations': 'Quotations',
  'bookings': 'Bookings',
  'operations': 'Operations',
  'itinerary': 'Itinerary',
  'visa': 'Visa & Documents',
  'inventory': 'Inventory',
  'documents': 'Documents',
  'vouchers': 'Vouchers',
  'finance': 'Finance',
  'pnl': 'P&L Analysis',
  'expenses': 'Expenses',
  'refunds': 'Refunds',
  'payments': 'Customer Payments',
  'vendors': 'Vendor Payments',
  'hr': 'HR & Payroll',
  'customers': 'Customer Database',
  'suppliers': 'Supplier Management',
  'commissions': 'Commission & Incentives',
  'approvals': 'Approval Center',
  'reports': 'Reports & MIS',
  'audit': 'Audit Logs',
  'iam': 'User Access Management',
  'settings': 'Settings'
};

// Show Page function
function showPage(name, el) {
  // Hide all .page-section
  document.querySelectorAll('.page-section').forEach(s => s.style.display = 'none');

  // Show selected page
  const pageId = 'pg-' + name;
  const page = document.getElementById(pageId);
  if (page) page.style.display = 'block';

  // Update sidebar active state
  document.querySelectorAll('.nav-item').forEach(item => {
    item.classList.remove('active');
    if (item.getAttribute('data-page') === name) {
      item.classList.add('active');
    }
  });

  // Update topbar title
  const titleEl = document.getElementById('topbarTitle');
  if (titleEl) {
    titleEl.textContent = PAGE_TITLES[name] || name;
  }

  // Initialize charts for the selected page
  var chartInits = {
    'dashboard': initDashboardCharts,
    'finance': initFinanceCharts,
    'pnl': initPnlCharts,
    'expenses': initExpenseCharts,
    'leads': initLeadCharts
  };
  if (chartInits[name]) {
    setTimeout(chartInits[name], 150);
  }
}

// DOMContentLoaded - attach nav click handlers
document.addEventListener('DOMContentLoaded', function() {
  // Attach click to all .nav-item[data-page]
  document.querySelectorAll('.nav-item[data-page]').forEach(item => {
    item.addEventListener('click', function(e) {
      e.preventDefault();
      const pageName = this.getAttribute('data-page');
      showPage(pageName, this);
    });
  });

  // Show dashboard by default
  showPage('dashboard');

  // Set current date
  const now = new Date();
  const dateStr = now.toLocaleDateString('en-IN');
  const dateEl = document.querySelector('.topbar .date');
  if (dateEl) dateEl.textContent = dateStr;

  // Init dashboard charts
  setTimeout(() => {
    initDashboardCharts();
  }, 200);
});

